{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.6.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "predev": "npm run clean",
    "prebuild": "npm run clean",
    "dev": "npm run dev-native && concurrently \"npm run dev-dsp\" \"vite\"",
    "dev-native": "zx scripts/build-native.mjs --dev",
    "dev-dsp": "esbuild dsp/main.ts --watch --bundle --outfile=public/dsp.main.js",
    "build-native": "zx scripts/build-native.mjs",
    "build-dsp": "esbuild dsp/main.ts --bundle --outfile=public/dsp.main.js",
    "build-ui": "vite build",
    "build": "npm run build-dsp && npm run build-ui && npm run build-native",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "capture-storybook-screenshots": "node scripts/capture-storybook-screenshots.mjs",
    "lint": "eslint src dsp .storybook scripts/capture-storybook-screenshots.mjs vite.config.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@elemaudio/core": "^4.0.1",
    "@heroicons/react": "^2.2.0",
    "@use-gesture/react": "^10.3.1",
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.28.0",
    "invariant": "^2.2.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resize-observer-polyfill": "^1.5.1",
    "rimraf": "^6.1.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/invariant": "^2.2.37",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "zx": "^8.8.5"
  }
}
